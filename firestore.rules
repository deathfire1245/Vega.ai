rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    // Pillar 2: Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt']) && 
             data.keys().size() == 4 && // userId, email, displayName, createdAt
             data.userId is string && data.userId.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.createdAt is timestamp &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 256));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
                      isValidId(userId) && 
                      isValidUser(incoming()) && 
                      incoming().userId == userId &&
                      incoming().createdAt == request.time;
      allow update: if isOwner(userId) && 
                      isValidUser(incoming()) &&
                      incoming().userId == existing().userId &&
                      incoming().createdAt == existing().createdAt;

      // Brand Brain Rules
      match /brandBrain/{brainDocId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
